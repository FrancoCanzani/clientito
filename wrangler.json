{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hauler",
  "main": "./src/worker/index.ts",
  "compatibility_date": "2025-10-08",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "upload_source_maps": true,
  "durable_objects": {
    "bindings": [{ "name": "Agent", "class_name": "Agent" }]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["EmailAgent"] },
    {
      "tag": "v2",
      "renamed_classes": [{ "from": "EmailAgent", "to": "Agent" }]
    }
  ],
  "assets": {
    "directory": "./dist/client",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*", "/sdk/*", "/agents/*"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "releaselayer-db",
      "database_id": "LOCAL",
      "migrations_dir": "drizzle"
    }
  ],
  "r2_buckets": [
    {
      "binding": "NOTES_IMAGES",
      "bucket_name": "releaselayer-notes-images"
    },
    {
      "binding": "ATTACHMENTS",
      "bucket_name": "releaselayer-attachments"
    }
  ],
  "vars": {
    "GOOGLE_CLIENT_ID": "",
    "GOOGLE_CLIENT_SECRET": "",
    "BETTER_AUTH_SECRET": "",
    "BETTER_AUTH_URL": "http://localhost:5173",
    "OPENAI_API_KEY": ""
  },
  "ai": {
    "binding": "AI"
  }
}
