{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "petit",
	"main": "./src/worker/index.ts",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": [
				"EmailAgent"
			]
		},
		{
			"tag": "v2",
			"renamed_classes": [
				{
					"from": "EmailAgent",
					"to": "Agent"
				}
			]
		},
		{
			"tag": "v3",
			"new_sqlite_classes": [
				"AgentSQLite"
			]
		},
		{
			"tag": "v4",
			"deleted_classes": [
				"Agent",
				"AgentSQLite"
			]
		}
	],
	"assets": {
		"directory": "./dist/client",
		"not_found_handling": "single-page-application",
		"run_worker_first": [
			"/api/*",
			"/sdk/*"
		]
	},
		"d1_databases": [
			{
				"binding": "DB",
				"database_name": "petit-db",
				"database_id": "de15a119-b406-4b57-9158-063f939849fe",
				"migrations_dir": "drizzle"
			}
		],
	"r2_buckets": [
		{
			"binding": "ATTACHMENTS",
			"bucket_name": "petit-attachments"
		}
	],
		"vars": {
			"BETTER_AUTH_URL": "https://petit.francocanzani.workers.dev"
		},
	"triggers": {
		"crons": [
			"*/1 * * * *",
			"0 * * * *"
		]
	}
}
