    "@tanstack/router-plugin": "^1.162.6",
    "@types/diff": "^8.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "^0.30.0",
    "eslint": "9.39.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.24",
    "globals": "16.5.0",
    "knip": "^6.0.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "8.48.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.67.1"
  },
  "private": true,
  "scripts": {
    "build": "tsc -b && vite build",
    "check-types": "tsc -b --pretty false --force",
    "cf-typegen": "wrangler types",
    "check": "tsc && vite build && wrangler deploy --dry-run",
    "deploy": "bun run build && wrangler deploy",
    "dev": "vite",
    "lint": "eslint .",
    "preview": "bun run build && vite preview",
    "db:generate": "bunx drizzle-kit generate --config=drizzle.worker.config.ts",
    "db:migrate:dev": "bunx wrangler d1 migrations apply petit-db --local",
    "db:migrate:prod": "bunx wrangler d1 migrations apply petit-db --remote",
    "db:reset:dev": "rm -rf .wrangler/state && bun run db:migrate:dev",
    "knip": "knip",
    "scheduled": "wrangler dev --test-scheduled --port 8787",
    "scheduled:trigger": "curl -s \"http://localhost:8787/__scheduled?cron=*/1+*+*+*+*\""
  },
  "type": "module"
}
